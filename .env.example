# ---- LLM providers ----
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# ---- Models ----
ANTHROPIC_MODEL=claude-sonnet-4-6
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536

# ---- Reranker ----
# Local cross-encoder model from HuggingFace (loaded into memory at boot).
# Empty disables reranking and falls back to RRF-only ordering.
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# ---- Database ----
POSTGRES_USER=rag
POSTGRES_PASSWORD=rag
POSTGRES_DB=rag
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://rag:rag@postgres:5432/rag

# ---- API ----
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000

# ---- Retrieval tuning ----
CHUNK_SIZE_TOKENS=512
CHUNK_OVERLAP_TOKENS=64
RETRIEVE_TOP_K_BM25=20
RETRIEVE_TOP_K_SEMANTIC=20
RRF_K=60
RERANK_TOP_K=5

# ---- Ingestion ----
ARXIV_QUERY=cat:cs.AI OR cat:cs.CL OR cat:cs.LG
ARXIV_MAX_PAPERS=100

# ---- Frontend ----
NEXT_PUBLIC_API_BASE=http://localhost:8000
